pkgname=pearos-dock
pkgver=26.6.8
pkgrel=1
pkgdesc="Tahoe-style dock for KDE Plasma 6"
arch=('x86_64')
url="https://github.com/pearOS-ArchLinux/pearos-dock"
license=('GPL-2.0-or-later')
depends=(
    'qt6-base'
    'qt6-declarative'
    'ki18n'
    'pear-temp-fix'
)
makedepends=(
    'cmake'
    'extra-cmake-modules'
    'gcc'
    'qt6-base'
    'ki18n'
    'kservice'
    'kwindowsystem'
    'kconfig'
    'kconfigwidgets'
    'kcoreaddons'
    'kitemmodels'
    'plasma-workspace'
    'kwin'
    'plasma-activities'
)
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('8c6e72d5ed7596411148f143fd5668b836af46c9d913e25b1d8a042a706dd5ca')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    cmake -B build \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr
    make -C build -j$(nproc)
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    make -C build DESTDIR="$pkgdir" install

    local skinsrc="$srcdir/$pkgname-$pkgver/package/contents/skins"
    local skindst="$pkgdir/usr/share/plasma/plasmoids/PearDock/contents/skins"
    install -dm755 "$skindst"
    cp -r "$skinsrc"/. "$skindst/"
}
