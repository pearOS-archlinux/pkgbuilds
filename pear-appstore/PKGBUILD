pkgname=pearos-appstore
pkgver=26.4.0
pkgrel=1
pkgdesc="pearOS AppStore - modern Qt6 app store for Arch-based systems"
arch=('x86_64')
url="https://pearos.xyz"
license=('MIT')
depends=('qt6-base' 'pacman')
makedepends=('cmake' 'qt6-base' 'pkgconf')
source=()
sha256sums=()

build() {
  # PKGBUILD is expected to live in the CMake build directory.
  # The real source tree is one level up from startdir.
  local srcroot="${startdir}/.."

  mkdir -p "${startdir}/cmake-pkg"
  cd "${startdir}/cmake-pkg"

  cmake "${srcroot}" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr

  cmake --build . -- -j"$(nproc)"
}

package() {
  cd "${startdir}/cmake-pkg"
  make DESTDIR="${pkgdir}" install
}

