# Maintainer : Alexandru Balan <alex@pear-software.com>

pkgname=system-settings
_realname=system-settings
pkgdesc="pearOS System Settings application (Qt6/QML)"
pkgver=26.6.1
pkgrel=1
arch=('x86_64')
depends=('qt6-base' 'qt6-declarative' 'qt6-5compat'
         'net-tools' 'fprintd' 'power-profiles-daemon' 'jq' 'piri-base')
makedepends=('cmake' 'qt6-tools')
url="https://pearos.xyz"
license=('GPLv3')
source=("file://${startdir}/license.txt"
        "file://${startdir}/pearos-systemsettings.desktop"
        "file://${startdir}/launch.sh"
        "file://${startdir}/hide-systemsettings.menu")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

prepare() {
  cp -r "${startdir}/assets"       "${srcdir}/assets"
  cp -r "${startdir}/backend"      "${srcdir}/backend"
  cp -r "${startdir}/qml"          "${srcdir}/qml"
  cp -r "${startdir}/themeswitcher" "${srcdir}/themeswitcher"
  cp    "${startdir}/main.cpp"       "${srcdir}/main.cpp"
  cp    "${startdir}/CMakeLists.txt" "${srcdir}/CMakeLists.txt"
}

build() {
  cmake -S "${srcdir}" -B "${srcdir}/build" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build "${srcdir}/build" --parallel
}

package() {
  install -d "${pkgdir}/usr/share/extras/${_realname}"
  install -m755 "${srcdir}/build/SystemSettings" \
    "${pkgdir}/usr/share/extras/${_realname}/SystemSettings"

  cp -r "${srcdir}/assets"       "${pkgdir}/usr/share/extras/${_realname}/assets"
  cp -r "${srcdir}/themeswitcher" "${pkgdir}/usr/share/extras/${_realname}/themeswitcher"
  chmod +x "${pkgdir}/usr/share/extras/${_realname}/themeswitcher/kde-theme-switch.sh"

  install -d "${pkgdir}/usr/bin"
  install -m755 "${srcdir}/launch.sh" "${pkgdir}/usr/bin/systemsettings1"

  install -Dm644 "${srcdir}/pearos-systemsettings.desktop" \
    "${pkgdir}/usr/share/applications/pearos-systemsettings.desktop"

  install -Dm644 "${srcdir}/license.txt" \
    "${pkgdir}/usr/share/licenses/pearos-system-settings/license.txt"

  install -Dm644 "${srcdir}/hide-systemsettings.menu" \
    "${pkgdir}/etc/xdg/menus/applications-merged/hide-systemsettings.menu"
}
