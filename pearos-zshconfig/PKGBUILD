license=('MIT')
source=('.zshrc')
sha256sums=('SKIP')

package() {
  install -Dm644 "${srcdir}/.zshrc" "${pkgdir}/root/.zshrc"
  install -Dm644 "${srcdir}/.zshrc" "${pkgdir}/etc/skel/.zshrc"
}
